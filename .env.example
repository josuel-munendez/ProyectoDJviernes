# ==========================================
# Configuración del Proyecto CRM
# ==========================================
# Copia este archivo como .env y ajusta según tu entorno.
# Por defecto usa SQLite, sin necesidad de MySQL.
#
# Para usar MySQL, instala mysqlclient:
#   Linux: sudo apt install default-libmysqlclient-dev && pip install mysqlclient
#   Mac:   brew install mysql-client && pip install mysqlclient
#   Windows: pip install mysqlclient  (requiere MS VC++ Build Tools)
# Luego descomenta y ajusta las variables DJANGO_DB_* abajo.

# --- Django ---
DJANGO_SECRET_KEY=django-insecure-wrd@k5c63l-25ln)85jwma^uf$he_n077de(m!-(rhiu5#*d+q
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# --- Base de datos (SQLite por defecto) ---
# Sin configurar => SQLite (db.sqlite3 en dcrm/)
# Para MySQL, descomenta y personaliza:
# DJANGO_DB_ENGINE=mysql
# DJANGO_DB_NAME=dcrm
# DJANGO_DB_USER=dcrm_user
# DJANGO_DB_PASSWORD=DcrmPass2026!
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=3306
